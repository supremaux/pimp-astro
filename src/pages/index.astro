---
import {
  ArrowLeft,
  ArrowRight,
  Award,
  Bookmark,
  Compass,
  Info,
  Mail,
  MapPin,
  Menu,
  MessageSquare,
  Palette,
  Phone,
  Sparkles,
  Truck,
  UserCheck,
  X,
} from "@lucide/astro";
import "../styles/global.css";
import { Image } from "astro:assets";
---

<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Pimp My Cake | Bolos Artísticos e Doces Finos em Campo Grande/MS
    </title>
    <meta
      name="description"
      content="Protótipo fictício de uma confeitaria boutique especializada em bolos artísticos, doces finos e experiências gastronômicas sofisticadas."
    />

    <!-- Open Graph / SEO -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Pimp My Cake | Bolos Artísticos e Doces Finos"
    />
    <meta
      property="og:description"
      content="Protótipo conceitual de confeitaria boutique de alto luxo. Jardim dos Estados, Campo Grande/MS."
    />
    <meta
      property="og:image"
      content="https://images.unsplash.com/photo-1535141192574-5d4897c13636?auto=format&fit=crop&q=80&w=1200"
    />

    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <!-- HEADER FIXO E ELEGANTE -->
    <header
      id="header"
      class="fixed top-0 left-0 w-full z-50 transition-all duration-300 py-6 px-6 lg:px-16 flex items-center justify-between"
    >
      <a
        href="#inicio"
        class="text-xl lg:text-2xl font-light tracking-[0.2em] uppercase text-luxuryText hover:opacity-75 transition-opacity"
      >
        Pimp My Cake
      </a>

      <!-- Navegação Desktop -->
      <nav
        class="hidden md:flex items-center space-x-8 text-xs tracking-[0.1em] uppercase font-medium"
      >
        <a
          href="#inicio"
          class="hover:text-luxuryGray transition-colors duration-200">Início</a
        >
        <a
          href="#sobre"
          class="hover:text-luxuryGray transition-colors duration-200">Sobre</a
        >
        <a
          href="#criacoes"
          class="hover:text-luxuryGray transition-colors duration-200"
          >Criações</a
        >
        <a
          href="#diferenciais"
          class="hover:text-luxuryGray transition-colors duration-200"
          >Diferenciais</a
        >
        <a
          href="#experiencia"
          class="hover:text-luxuryGray transition-colors duration-200"
          >Experiência</a
        >
        <a
          href="#encomendas"
          class="hover:text-luxuryGray transition-colors duration-200"
          >Encomendas</a
        >
      </nav>

      <div class="hidden lg:block">
        <a
          href="#encomendas"
          class="luxury-button text-xs border border-luxuryText px-6 py-3 hover:bg-luxuryText hover:text-white inline-block"
        >
          Solicitar Encomenda
        </a>
      </div>

      <!-- Mobile Menu Trigger -->
      <button
        id="menuBtn"
        class="md:hidden text-luxuryText focus:outline-none"
        aria-label="Abrir Menu"
      >
        <Menu class="w-6 h-6" />
      </button>
    </header>

    <!-- MOBILE NAVIGATION OVERLAY -->
    <div
      id="mobileMenu"
      class="fixed inset-0 bg-white z-40 translate-x-full transition-transform duration-500 ease-in-out flex flex-col justify-between p-8 pt-24 md:hidden"
    >
      <nav
        class="flex flex-col space-y-6 text-lg tracking-[0.15em] uppercase font-light"
      >
        <a href="#inicio" class="mobile-link py-2 border-b border-gray-100"
          >Início</a
        >
        <a href="#sobre" class="mobile-link py-2 border-b border-gray-100"
          >Sobre</a
        >
        <a href="#criacoes" class="mobile-link py-2 border-b border-gray-100"
          >Criações</a
        >
        <a
          href="#diferenciais"
          class="mobile-link py-2 border-b border-gray-100">Diferenciais</a
        >
        <a href="#experiencia" class="mobile-link py-2 border-b border-gray-100"
          >Experiência</a
        >
        <a href="#encomendas" class="mobile-link py-2 border-b border-gray-100"
          >Encomendas</a
        >
      </nav>

      <div class="space-y-6">
        <a
          href="#encomendas"
          class="mobile-link luxury-button text-center block text-xs border border-luxuryText w-full py-4 hover:bg-luxuryText hover:text-white"
        >
          Solicitar Encomenda
        </a>
        <div
          class="text-[10px] text-luxuryGray tracking-widest uppercase text-center"
        >
          Campo Grande/MS
        </div>
      </div>
    </div>

    <!-- HERO SECTION -->
    <section
      id="inicio"
      class="min-h-screen relative flex flex-col justify-end lg:justify-center pt-32 pb-16 px-6 lg:px-16 overflow-hidden bg-white"
    >
      <!-- Visual Background / Grid Editorial -->
      <div
        class="absolute right-0 top-0 w-full lg:w-1/2 h-[55vh] lg:h-full z-0"
      >
        <div class="relative w-full h-full">
          <!-- Imagem do bolo de luxo editorial -->
          <Image
            src="https://images.unsplash.com/photo-1605563432942-0f863d9df42e?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
            crossorigin="anonymous"
            alt="Bolo de Casamento de Luxo"
            width="1200"
            height="800"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t lg:bg-gradient-to-r from-white via-white/50 lg:via-white/70 to-transparent"
          >
          </div>
        </div>
      </div>

      <!-- Conteúdo do Hero -->
      <div class="relative z-10 w-full lg:w-7/12 mt-[35vh] lg:mt-0">
        <div class="space-y-6 lg:space-y-8 max-w-3xl">
          <!-- Sutil tag de localização -->
          <div
            class="inline-flex items-center space-x-2 text-xs tracking-[0.2em] uppercase text-luxuryGray"
          >
            <span class="w-2 h-2 rounded-full bg-roseSophisticated"></span>
            <span>Jardim dos Estados • Campo Grande/MS</span>
          </div>

          <h1 class="hero-title text-luxuryText">
            Transformamos celebrações em obras de arte comestíveis.
          </h1>

          <p
            class="editorial-text text-luxuryGray text-sm lg:text-base max-w-xl"
          >
            Bolos artísticos e doces autorais criados sob medida para momentos
            extraordinários. Cada detalhe esculpido à mão para contar a sua
            história de forma memorável.
          </p>

          <!-- Botões de Ação -->
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a
              href="#encomendas"
              class="luxury-button text-center text-xs bg-luxuryText text-white px-8 py-4 border border-luxuryText hover:bg-white hover:text-luxuryText"
            >
              Solicitar Encomenda
            </a>
            <a
              href="#criacoes"
              class="luxury-button text-center text-xs border border-luxuryText/20 text-luxuryText px-8 py-4 hover:border-luxuryText bg-white/50 backdrop-blur-sm"
            >
              Conhecer Criações
            </a>
          </div>
        </div>
      </div>

      <!-- Divisor sutil no final do Hero -->
      <div
        class="absolute bottom-6 left-6 lg:left-16 hidden lg:flex items-center space-x-4 text-xs tracking-widest text-luxuryGray/60"
      >
        <span>SCROLL</span>
        <span class="w-12 h-[1px] bg-luxuryGray/30"></span>
      </div>
    </section>

    <!-- SEÇÃO SOBRE -->
    <section id="sobre" class="py-24 lg:py-32 px-6 lg:px-16 bg-luxuryLight">
      <div class="max-w-7xl mx-auto">
        <div
          class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center"
        >
          <!-- Coluna de Imagem / Editorial Layout -->
          <div class="col-span-1 lg:col-span-5 relative reveal">
            <div class="aspect-[3/4] overflow-hidden bg-neutral-200">
              <Image
                src="https://images.unsplash.com/photo-1709837167684-47d7ccf0ed89?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                alt="Confeiteira decorando doce fino"
                class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
                width="1000"
                height="667"
              />
            </div>
            <!-- Elemento decorativo discreto em tom pastel -->
            <div
              class="absolute -bottom-6 -right-6 w-32 h-32 bg-roseSophisticated/40 -z-10"
            >
            </div>
          </div>

          <!-- Coluna de Texto -->
          <div class="col-span-1 lg:col-span-7 space-y-8 reveal">
            <div class="space-y-4">
              <span
                class="text-xs tracking-[0.2em] uppercase text-luxuryGray block"
                >Filosofia Boutique</span
              >
              <h2
                class="text-3xl lg:text-5xl font-light tracking-tight text-luxuryText"
              >
                A arte da confeitaria elevada ao extraordinário.
              </h2>
            </div>

            <div
              class="space-y-6 text-sm lg:text-base text-luxuryGray editorial-text"
            >
              <p>
                Nascemos da paixão por unir alta confeitaria técnica e design
                contemporâneo. No coração do Jardim dos Estados, em Campo
                Grande, a <strong>Pimp My Cake</strong> cria experiências que vão
                muito além do sabor; criamos memórias esculpidas.
              </p>
              <p>
                Nossos bolos e doces são desenvolvidos através de uma curadoria
                meticulosa de ingredientes mundiais combinada a técnicas
                tradicionais da pâtisserie francesa. Sob o olhar detalhista e
                autoral de nossa equipe, cada encomenda é única, executada com
                precisão arquitetônica para coroar os momentos mais importantes
                da sua vida.
              </p>
            </div>

            <!-- Números Fictícios em Grid Minimalista -->
            <div
              class="grid grid-cols-3 gap-6 pt-8 border-t border-luxuryText/10"
            >
              <div>
                <div class="text-2xl lg:text-4xl font-light text-luxuryText">
                  12
                </div>
                <div
                  class="text-[10px] lg:text-xs tracking-wider uppercase text-luxuryGray mt-1"
                >
                  Anos de Tradição
                </div>
              </div>
              <div>
                <div class="text-2xl lg:text-4xl font-light text-luxuryText">
                  1.200
                </div>
                <div
                  class="text-[10px] lg:text-xs tracking-wider uppercase text-luxuryGray mt-1"
                >
                  Celebrações Atendidas
                </div>
              </div>
              <div>
                <div class="text-2xl lg:text-4xl font-light text-luxuryText">
                  98%
                </div>
                <div
                  class="text-[10px] lg:text-xs tracking-wider uppercase text-luxuryGray mt-1"
                >
                  Clientes Recorrentes
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SEÇÃO CRIAÇÕES -->
    <section id="criacoes" class="py-24 lg:py-32 px-6 lg:px-16 bg-white">
      <div class="max-w-7xl mx-auto">
        <div
          class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 space-y-6 md:space-y-0"
        >
          <div class="space-y-4">
            <span
              class="text-xs tracking-[0.2em] uppercase text-luxuryGray block"
              >Nosso Portfólio</span
            >
            <h2
              class="text-3xl lg:text-5xl font-light tracking-tight text-luxuryText"
            >
              Criações de Assinatura
            </h2>
          </div>
          <!-- Filtros elegantes para galeria -->
          <div
            class="flex flex-wrap gap-3 text-xs tracking-widest uppercase font-medium border-b border-gray-100 pb-2 w-full md:w-auto"
          >
            <button
              onclick="filterGallery('todos')"
              class="filter-btn active border-b-2 border-luxuryText pb-2 px-1 text-luxuryText transition-all"
            >
              Todos
            </button>
            <button
              onclick="filterGallery('bolos')"
              class="filter-btn border-b-2 border-transparent pb-2 px-1 text-luxuryGray hover:text-luxuryText transition-all"
            >
              Bolos Artísticos
            </button>
            <button
              onclick="filterGallery('casamentos')"
              class="filter-btn border-b-2 border-transparent pb-2 px-1 text-luxuryGray hover:text-luxuryText transition-all"
            >
              Casamentos
            </button>
            <button
              onclick="filterGallery('doces')"
              class="filter-btn border-b-2 border-transparent pb-2 px-1 text-luxuryGray hover:text-luxuryText transition-all"
            >
              Doces Finos
            </button>
            <button
              onclick="filterGallery('sazonais')"
              class="filter-btn border-b-2 border-transparent pb-2 px-1 text-luxuryGray hover:text-luxuryText transition-all"
            >
              Sazonais
            </button>
          </div>
        </div>

        <!-- Grid Editorial de Criações -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Item 1: Bolos Artísticos -->
          <div class="gallery-item bolos group reveal">
            <div
              class="aspect-[3/4] overflow-hidden bg-neutral-100 mb-4 relative"
            >
              <Image
                src="https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?auto=format&fit=crop&q=80&w=800"
                alt="Bolo Artístico Moderno com Flores"
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                width="800"
                height="533"
              />
              <div
                class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm text-[10px] tracking-widest uppercase px-3 py-1 text-luxuryText"
              >
                Bolos Artísticos
              </div>
            </div>
            <div class="space-y-1">
              <h3
                class="text-sm tracking-wider uppercase font-medium text-luxuryText"
              >
                Bolo Minimalista Escultural
              </h3>
              <p class="text-xs text-luxuryGray editorial-text">
                Conceito monolítico adornado por pétalas de açúcar estilizadas e
                texturas de gesso comestível.
              </p>
            </div>
          </div>

          <!-- Item 2: Casamentos -->
          <div class="gallery-item casamentos group reveal" data-delay="100">
            <div
              class="aspect-[3/4] overflow-hidden bg-neutral-100 mb-4 relative"
            >
              <Image
                src="https://images.unsplash.com/photo-1535254973040-607b474cb50d?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                alt="Bolo de Casamento Clássico e Elegante"
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                width="800"
                height="533"
              />
              <div
                class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm text-[10px] tracking-widest uppercase px-3 py-1 text-luxuryText"
              >
                Casamentos
              </div>
            </div>
            <div class="space-y-1">
              <h3
                class="text-sm tracking-wider uppercase font-medium text-luxuryText"
              >
                Couture Wedding Cake
              </h3>
              <p class="text-xs text-luxuryGray editorial-text">
                Estruturas imponentes de múltiplos andares, babados de papel de
                arroz ultra finos e texturas etéreas.
              </p>
            </div>
          </div>

          <!-- Item 3: Doces Finos -->
          <div class="gallery-item doces group reveal" data-delay="200">
            <div
              class="aspect-[3/4] overflow-hidden bg-neutral-100 mb-4 relative"
            >
              <Image
                src="https://images.unsplash.com/photo-1551024601-bec78aea704b?auto=format&fit=crop&q=80&w=800"
                alt="Macarons de Baunilha e Flores"
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                width="800"
                height="533"
              />
              <div
                class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm text-[10px] tracking-widest uppercase px-3 py-1 text-luxuryText"
              >
                Doces Finos
              </div>
            </div>
            <div class="space-y-1">
              <h3
                class="text-sm tracking-wider uppercase font-medium text-luxuryText"
              >
                Pâtisserie d'Art
              </h3>
              <p class="text-xs text-luxuryGray editorial-text">
                Macarons metalizados, tartelettes decoradas com pó de ouro 24k e
                trufas esculpidas em formatos orgânicos.
              </p>
            </div>
          </div>

          <!-- Item 4: Coleções Sazonais -->
          <div class="gallery-item sazonais group reveal" data-delay="300">
            <div
              class="aspect-[3/4] overflow-hidden bg-neutral-100 mb-4 relative"
            >
              <Image
                src="https://images.unsplash.com/photo-1542826438-bd32f43d626f?auto=format&fit=crop&q=80&w=800"
                alt="Coleção Festiva de Chocolates Finos"
                class="w-full h-full object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                width="800"
                height="533"
              />
              <div
                class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              >
              </div>
              <div
                class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm text-[10px] tracking-widest uppercase px-3 py-1 text-luxuryText"
              >
                Coleções Sazonais
              </div>
            </div>
            <div class="space-y-1">
              <h3
                class="text-sm tracking-wider uppercase font-medium text-luxuryText"
              >
                Coleção Equinócio
              </h3>
              <p class="text-xs text-luxuryGray editorial-text">
                Edições limitadas inspiradas nas estações do ano, com
                ingredientes colhidos em época exata e embalagens de design.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SEÇÃO DIFERENCIAIS -->
    <section
      id="diferenciais"
      class="py-24 lg:py-32 px-6 lg:px-16 bg-luxuryLight"
    >
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-24 space-y-4">
          <span class="text-xs tracking-[0.2em] uppercase text-luxuryGray block"
            >Por que Pimp My Cake</span
          >
          <h2
            class="text-3xl lg:text-5xl font-light tracking-tight text-luxuryText"
          >
            Os pilares da nossa exclusividade
          </h2>
          <div class="w-12 h-[1px] bg-luxuryText/20 mx-auto mt-6"></div>
        </div>

        <!-- Grid de Diferenciais (Cards Minimalistas com Ícones Lucide) -->
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12"
        >
          <!-- Card 1: Ingredientes Premium -->
          <div
            class="bg-white p-8 lg:p-10 border border-luxuryText/5 hover:border-luxuryText/20 transition-all duration-300 flex flex-col justify-between group reveal"
          >
            <div class="space-y-6">
              <div
                class="w-12 h-12 rounded-full bg-vanilla flex items-center justify-center text-luxuryText group-hover:scale-110 transition-transform duration-300"
              >
                <Award class="w-5 h-5 stroke-[1.5]" />
              </div>
              <h3
                class="text-base tracking-wider uppercase font-medium text-luxuryText"
              >
                Ingredientes Premium
              </h3>
              <p class="text-sm text-luxuryGray editorial-text">
                Chocolates de origem belga e francesa, favas de baunilha de
                Madagascar e frutas selecionadas localmente em sua maturidade
                ideal.
              </p>
            </div>
            <div
              class="pt-6 text-xs tracking-widest uppercase text-luxuryGray/60 group-hover:text-luxuryText transition-colors duration-300 mt-4"
            >
              Matéria-Prima Exclusiva
            </div>
          </div>

          <!-- Card 2: Produção Artesanal -->
          <div
            class="bg-white p-8 lg:p-10 border border-luxuryText/5 hover:border-luxuryText/20 transition-all duration-300 flex flex-col justify-between group reveal"
            data-delay="100"
          >
            <div class="space-y-6">
              <div
                class="w-12 h-12 rounded-full bg-roseSophisticated/40 flex items-center justify-center text-luxuryText group-hover:scale-110 transition-transform duration-300"
              >
                <Sparkles class="w-5 h-5 stroke-[1.5]" />
              </div>
              <h3
                class="text-base tracking-wider uppercase font-medium text-luxuryText"
              >
                Produção Artesanal
              </h3>
              <p class="text-sm text-luxuryGray editorial-text">
                Sem atalhos industriais ou misturas comerciais. Cada recheio,
                cobertura e escultura decorativa é feita do zero, em ritmo
                artesanal.
              </p>
            </div>
            <div
              class="pt-6 text-xs tracking-widest uppercase text-luxuryGray/60 group-hover:text-luxuryText transition-colors duration-300 mt-4"
            >
              Artesanato Puro
            </div>
          </div>

          <!-- Card 3: Atendimento Exclusivo -->
          <div
            class="bg-white p-8 lg:p-10 border border-luxuryText/5 hover:border-luxuryText/20 transition-all duration-300 flex flex-col justify-between group reveal"
            data-delay="200"
          >
            <div class="space-y-6">
              <div
                class="w-12 h-12 rounded-full bg-champagne flex items-center justify-center text-luxuryText group-hover:scale-110 transition-transform duration-300"
              >
                <UserCheck class="w-5 h-5 stroke-[1.5]" />
              </div>
              <h3
                class="text-base tracking-wider uppercase font-medium text-luxuryText"
              >
                Atendimento Exclusivo
              </h3>
              <p class="text-sm text-luxuryGray editorial-text">
                Apenas uma quantidade estritamente limitada de encomendas é
                aceita a cada semana, garantindo atenção irrestrita ao seu
                projeto.
              </p>
