<!-- JAVASCRIPT: Interatividade e UX -->
<script is:inline>
  // Scroll Event: Mudar comportamento do Header
  window.addEventListener("scroll", function () {
    const header = document.getElementById("header");
    if (window.scrollY > 50) {
      header.classList.add("header-scrolled");
    } else {
      header.classList.remove("header-scrolled");
    }
  });

  // Menu Mobile (Toggle)
  const menuBtn = document.getElementById("menuBtn");
  const mobileMenu = document.getElementById("mobileMenu");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  function toggleMenu() {
    const isOpened = mobileMenu.classList.contains("translate-x-0");
    if (isOpened) {
      mobileMenu.classList.remove("translate-x-0");
      mobileMenu.classList.add("translate-x-full");
      menuBtn.innerHTML = '<Menu class="w-6 h-6" />';
    } else {
      mobileMenu.classList.remove("translate-x-full");
      mobileMenu.classList.add("translate-x-0");
      menuBtn.innerHTML = '<X class="w-6 h-6" />';
    }
    lucide.createIcons();
  }

  menuBtn.addEventListener("click", toggleMenu);
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.remove("translate-x-0");
      mobileMenu.classList.add("translate-x-full");
      menuBtn.innerHTML = '<Menu class="w-6 h-6" />';
      lucide.createIcons();
    });
  });

  // Filtro da Galeria (Criações)
  function filterGallery(category) {
    // Atualizar classes dos botões
    const buttons = document.querySelectorAll(".filter-btn");
    buttons.forEach((btn) => {
      btn.classList.remove("active", "border-luxuryText", "text-luxuryText");
      btn.classList.add("border-transparent", "text-luxuryGray");
    });

    // Adicionar destaque ao botão atual
    const clickedBtn = event.currentTarget;
    clickedBtn.classList.remove("border-transparent", "text-luxuryGray");
    clickedBtn.classList.add("active", "border-luxuryText", "text-luxuryText");

    // Filtrar os elementos
    const items = document.querySelectorAll(".gallery-item");
    items.forEach((item) => {
      if (category === "todos") {
        item.style.display = "block";
      } else {
        if (item.classList.contains(category)) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      }
    });
  }

  // Controle do Carrossel de Depoimentos
  let currentSlide = 0;
  const totalSlides = 3;
  const container = document.getElementById("testimonialContainer");
  const dots = document.querySelectorAll(".dot");

  function updateTestimonial() {
    container.style.transform = `translateX(-${currentSlide * 100}%)`;
    dots.forEach((dot, index) => {
      if (index === currentSlide) {
        dot.classList.remove("bg-luxuryText/20");
        dot.classList.add("bg-luxuryText");
      } else {
        dot.classList.remove("bg-luxuryText");
        dot.classList.add("bg-luxuryText/20");
      }
    });
  }

  function nextTestimonial() {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateTestimonial();
  }

  function prevTestimonial() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateTestimonial();
  }

  function setTestimonial(index) {
    currentSlide = index;
    updateTestimonial();
  }

  // AutoPlay sutil para o carrossel (a cada 7 segundos)
  setInterval(nextTestimonial, 7000);

  // Formulário de Encomenda: Envio Fictício & Modal
  function handleFormSubmit(event) {
    event.preventDefault(); // Impede o recarregamento padrão do navegador

    // Exibir o Modal customizado de forma fluida
    const modal = document.getElementById("feedbackModal");
    modal.classList.remove("opacity-0", "pointer-events-none");
    modal.classList.add("opacity-100");

    // Resetar opcionalmente o formulário
    document.getElementById("orderForm").reset();
  }

  function closeModal() {
    const modal = document.getElementById("feedbackModal");
    modal.classList.remove("opacity-100");
    modal.classList.add("opacity-0", "pointer-events-none");
  }

  // Revelar Elementos Sutilmente no Scroll (Motion Design)
  function reveal() {
    const reveals = document.querySelectorAll(".reveal");
    reveals.forEach((element) => {
      const windowHeight = window.innerHeight;
      const elementTop = element.getBoundingClientRect().top;
      const elementVisible = 150;

      if (elementTop < windowHeight - elementVisible) {
        element.classList.add("active");
      }
    });
  }

  window.addEventListener("scroll", reveal);
  // Rodar no load para elementos que já estão na tela de cara
  window.addEventListener("load", reveal);
</script>

